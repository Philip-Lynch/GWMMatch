Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"nFreq", "=", 
   RowBox[{
    RowBox[{"Floor", "[", 
     RowBox[{"nTime", "/", "2"}], "]"}], "+", "1"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"psdFlat", "=", 
    RowBox[{"FlatPSD", "[", 
     RowBox[{"nFreq", ",", "deltaF", ",", "fLow"}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "A", " ", "slightly", " ", "different", " ", "sinusoid", " ", "at", " ", 
    "with", " ", "perturned", " ", "f", " ", "and", " ", "fdot", " ", "Hz"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Delta]f", " ", "=", " ", "0.001"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Delta]fdot", " ", "=", " ", "0.1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"hRef", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"2.0", " ", "Pi", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"f0", "+", "\[Delta]f"}], ")"}], " ", "+", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"fdot", " ", "+", " ", "\[Delta]fdot"}], ")"}], " ", 
          "t"}]}], ")"}], " ", "t"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "tVals"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"hRefTapered", "=", 
    RowBox[{"GWTaper", "[", "hRef", "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{"plotTimeStart", "=", 
  RowBox[{"ListPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"tVals", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "nShow"}], "]"}], "]"}], ",", 
         RowBox[{"hSharp", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "nShow"}], "]"}], "]"}]}], "}"}], "]"}], ",", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"tVals", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "nShow"}], "]"}], "]"}], ",", 
         RowBox[{"hRef", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "nShow"}], "]"}], "]"}]}], "}"}], "]"}]}], 
     "}"}], ",", 
    RowBox[{"Joined", "->", "True"}], ",", 
    RowBox[{"PlotStyle", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", "Thick", "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Dashed"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Dashed"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"PlotLegends", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<\!\(\*SubscriptBox[\(h\), \(1\)]\)\>\"", 
       ",", "\"\<\!\(\*SubscriptBox[\(h\), \(2\)]\)\>\""}], "}"}]}], ",", 
    RowBox[{"PlotLabel", "->", "\"\<Waveform start\>\""}], ",", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<t [s]\>\"", ",", "\"\<h(t)\>\""}], "}"}]}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
    RowBox[{"ImageSize", "->", "600"}]}], "]"}]}]}], "Input",
