Cell[CellGroupData[{

Cell["3. Frequency-domain: spectral leakage  ", "Subsection",
 CellChangeTimes->{
  3.987572175904448*^9},ExpressionUUID->"e528d20f-d37f-405f-8489-\
e2090259fcf6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Compute", " ", "one"}], "-", 
    RowBox[{"sided", " ", "ASDs"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"asdOf", "[", "h_", "]"}], ":=", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"nF", "=", 
          RowBox[{
           RowBox[{"Floor", "[", 
            RowBox[{"nTime", "/", "2"}], "]"}], "+", "1"}]}], ",", 
         RowBox[{"fft", "=", 
          RowBox[{"GWMMatch`Private`ForwardFFT", "[", 
           RowBox[{"h", ",", "deltaT"}], "]"}]}]}], "}"}], ",", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"k", "-", "1"}], ")"}], "*", "deltaF"}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", "1", ",", "nF"}], "}"}]}], "]"}], ",", 
          RowBox[{
           RowBox[{"Abs", "[", "fft", "]"}], "*", "2.0", "*", "deltaT"}]}], 
         "  ", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"one", "-", 
            RowBox[{"sided", " ", "ASD"}]}], ",", "unnormalised"}], "*)"}], 
         "}"}], "]"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"asdSharp", "=", 
     RowBox[{"asdOf", "[", "hSharp", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"asdAuto", "=", 
     RowBox[{"asdOf", "[", "hTaperAuto", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"asdFixed", "=", 
     RowBox[{"asdOf", "[", "hTaperFixed", "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"plotASDFull", "=", 
    RowBox[{"ListLogLogPlot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"asdSharp", ",", "asdAuto", ",", "asdFixed"}], "}"}], ",", 
      RowBox[{"Joined", "->", "True"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", "Thick", "}"}], ",", 
         RowBox[{"{", "Thick", "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Thick", ",", "Dashed"}], "}"}]}], "}"}]}], ",", 
      RowBox[{"PlotLegends", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<Untapered\>\"", ",", "\"\<Planck taper (auto)\>\"", 
         ",", "\"\<Planck taper (200 samples)\>\""}], "}"}]}], ",", 
      RowBox[{
      "PlotLabel", 
       "->", "\"\<Full spectrum \[LongDash] spectral leakage \
suppression\>\""}], ",", 
      RowBox[{"AxesLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<f [Hz]\>\"", ",", "\"\<|h(f)|\>\""}], "}"}]}], ",", 
      RowBox[{"PlotRange", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"10", ",", "2000"}], "}"}], ",", "All"}], "}"}]}], ",", 
      RowBox[{"GridLines", "->", "Automatic"}], ",", 
      RowBox[{"GridLinesStyle", "->", "LightGray"}], ",", 
      RowBox[{"ImageSize", "->", "600"}]}], "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.987572198802959*^9, 3.987572223982799*^9}, {
  3.9875726357708683`*^9, 3.9875726429842033`*^9}, {3.9875726851223516`*^9, 
