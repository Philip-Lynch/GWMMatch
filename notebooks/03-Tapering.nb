Cell[CellGroupData[{

Cell["1.  Build a test signal ", "Subsection",
 CellChangeTimes->{{3.987572076243025*^9, 
  3.987572087796795*^9}},ExpressionUUID->"2f5bca2f-0e6d-4785-b4a9-\
537ba45e1792"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"sampleRate", "=", "2048.0"}], ";"}], "   ", 
  RowBox[{"(*", "Hz", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"duration", "=", "2.0"}], ";"}], "      ", 
  RowBox[{"(*", "seconds", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"f0", "=", "40.0"}], ";"}], "     ", 
  RowBox[{"(*", 
   RowBox[{"starting", " ", 
    RowBox[{"frequency", "[", "Hz", "]"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fDot", "=", "30.0"}], ";"}], "     ", 
  RowBox[{"(*", 
   RowBox[{"frequency", " ", "sweep", " ", 
    RowBox[{"rate", "[", 
     RowBox[{"Hz", "/", "s"}], "]"}]}], "*)"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"nTime", "=", 
   RowBox[{"Round", "[", 
    RowBox[{"sampleRate", "*", "duration"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"deltaT", "=", 
   RowBox[{"1.0", "/", "sampleRate"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"deltaF", "=", 
   RowBox[{"1.0", "/", "duration"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fLow", "=", "10.0"}], ";"}], "   ", 
  RowBox[{"(*", 
   RowBox[{"lower", " ", "frequency", " ", 
    RowBox[{"cutoff", "[", "Hz", "]"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fHigh", "=", "512.0"}], ";"}], "  ", 
  RowBox[{"(*", 
   RowBox[{"upper", " ", "frequency", " ", 
    RowBox[{"cutoff", "[", "Hz", "]"}]}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "A", " ", "pure", " ", "sinusoid", " ", "with", " ", "a", " ", "sharp", " ",
      "onset"}], "\[LongDash]", 
    RowBox[{"pathological", " ", "spectral", " ", "leakage"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f0", "=", "150.0"}], ";"}], "  ", 
  RowBox[{"(*", "Hz", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"fdot", " ", "=", " ", "30"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tVals", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"n", "*", "deltaT"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", 
       RowBox[{"nTime", "-", "1"}]}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"hSharp", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"2.0", " ", "Pi", " ", 
        RowBox[{"(", 
         RowBox[{"f0", " ", "+", " ", 
          RowBox[{"fdot", " ", "t"}]}], ")"}], " ", "t"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "tVals"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "Apply", " ", "tapers", " ", "with", " ", "three", " ", "different", " ", 
    "widths"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"hTaperAuto", "=", 
    RowBox[{"GWTaper", "[", "hSharp", "]"}]}], ";"}], 
  "                             ", 
  RowBox[{"(*", 
   RowBox[{"auto", "-", 
    RowBox[{"detect", " ", "width"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"hTaperFixed", "=", 
    RowBox[{"GWTaper", "[", 
     RowBox[{"hSharp", ",", "\"\<TAPER_STARTEND\>\"", ",", "200"}], "]"}]}], 
   ";"}], "     ", 
  RowBox[{"(*", 
   RowBox[{"200", " ", "samples", " ", "each", " ", "end"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"hTaperStart", "=", 
    RowBox[{"GWTaper", "[", 
     RowBox[{"hSharp", ",", "\"\<TAPER_START\>\""}], "]"}]}], ";"}], 
  "              ", 
  RowBox[{"(*", 
   RowBox[{"start", " ", "only"}], "*)"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Signal length: \>\"", ",", "nTime", ",", "\"\< samples\>\""}],
    "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.98757210269913*^9, 3.987572102701786*^9}, {
  3.9875730421915216`*^9, 3.987573056631625*^9}, {3.987573103509562*^9, 
  3.987573106115073*^9}, {3.987573145296673*^9, 3.9875731504138107`*^9}, {
  3.9875731890580053`*^9, 3.987573191860055*^9}},
 CellLabel->
  "In[398]:=",ExpressionUUID->"a5efd8e1-164d-4249-9fd5-a2120d4befd3"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Signal length: \"\>", "\[InvisibleSpace]", "4096", 
   "\[InvisibleSpace]", "\<\" samples\"\>"}],
  SequenceForm["Signal length: ", 4096, " samples"],
  Editable->False]], "Print",
 CellChangeTimes->{3.987572104964736*^9, 3.98757319523993*^9, 
  3.987573484526617*^9},
 CellLabel->
  "During evaluation of \
In[398]:=",ExpressionUUID->"f5d8f453-e17b-4a3d-ae18-4448d6810fed"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Time-domain view   ", "Subsection",
 CellChangeTimes->{
  3.987572130030949*^9},ExpressionUUID->"b97ea5da-1f7f-4bb9-bb61-\
6fc60e2a03dc"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"nShow", "=", "200"}], ";"}], "   ", 
  RowBox[{"(*", 
   RowBox[{
   "samples", " ", "to", " ", "display", " ", "at", " ", "each", " ", 
    "edge"}], "*)"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{"plotTimeStart", "=", 
  RowBox[{"ListPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"tVals", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "nShow"}], "]"}], "]"}], ",", 
         RowBox[{"hSharp", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "nShow"}], "]"}], "]"}]}], "}"}], "]"}], ",", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"tVals", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "nShow"}], "]"}], "]"}], ",", 
         RowBox[{"hTaperAuto", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "nShow"}], "]"}], "]"}]}], "}"}], "]"}], ",", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"tVals", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "nShow"}], "]"}], "]"}], ",", 
         RowBox[{"hTaperFixed", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "nShow"}], "]"}], "]"}]}], "}"}], "]"}]}], 
     "}"}], ",", 
    RowBox[{"Joined", "->", "True"}], ",", 
    RowBox[{"PlotStyle", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", "Thick", "}"}], ",", 
       RowBox[{"{", "Thick", "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Dashed"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"PlotLegends", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<Untapered\>\"", ",", "\"\<Planck taper (auto)\>\"", 
       ",", "\"\<Planck taper (200 samples)\>\""}], "}"}]}], ",", 
    RowBox[{
    "PlotLabel", 
     "->", "\"\<Waveform start \[LongDash] effect of Planck tapering\>\""}], ",", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<t [s]\>\"", ",", "\"\<h(t)\>\""}], "}"}]}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
    RowBox[{"ImageSize", "->", "600"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.987572139916868*^9, 3.987572158094936*^9}, 
   3.9875732028309317`*^9, {3.987573398824641*^9, 3.987573404846136*^9}, {
   3.987573948850647*^9, 3.987573948941265*^9}},
 CellLabel->
