Cell["\<\
The role of the taper is to suppress the power being spread to the higher and \
lower frequencies. \
\>", "Text",
 CellChangeTimes->{{3.987574290887746*^9, 3.9875743221921597`*^9}, {
  3.9875743759065523`*^9, 
  3.987574421057654*^9}},ExpressionUUID->"9d56c773-35a6-4506-934e-\
3c339358b352"]
}, Open  ]],

