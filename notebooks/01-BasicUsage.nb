Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"sampleRate", "=", "2048.0"}], ";"}], "   ", 
  RowBox[{"(*", "Hz", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"duration", "=", "2.0"}], ";"}], "      ", 
  RowBox[{"(*", "seconds", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"f0", "=", "50.0"}], ";"}], "     ", 
  RowBox[{"(*", 
   RowBox[{"starting", " ", 
    RowBox[{"frequency", "[", "Hz", "]"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fDot", "=", "25.0"}], ";"}], "     ", 
  RowBox[{"(*", 
   RowBox[{"frequency", " ", "sweep", " ", 
    RowBox[{"rate", "[", 
     RowBox[{"Hz", "/", "s"}], "]"}]}], "*)"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"nTime", "=", 
   RowBox[{"Round", "[", 
    RowBox[{"sampleRate", "*", "duration"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"deltaT", "=", 
   RowBox[{"1.0", "/", "sampleRate"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"deltaF", "=", 
   RowBox[{"1.0", "/", "duration"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fLow", "=", "20.0"}], ";"}], "   ", 
  RowBox[{"(*", 
   RowBox[{"lower", " ", "frequency", " ", 
    RowBox[{"cutoff", "[", "Hz", "]"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fHigh", "=", "512.0"}], ";"}], "  ", 
  RowBox[{"(*", 
   RowBox[{"upper", " ", "frequency", " ", 
    RowBox[{"cutoff", "[", "Hz", "]"}]}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Reference", " ", 
    RowBox[{"waveform", ":", 
     RowBox[{
      RowBox[{"a", " ", "frequency"}], "-", 
      RowBox[{
      "swept", " ", "sinusoid", " ", "with", " ", "a", " ", "Planck", " ", 
       "taper"}]}]}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"tVals", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"n", "*", "deltaT"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", 
       RowBox[{"nTime", "-", "1"}]}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"h1Raw", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"2", " ", "Pi", " ", 
        RowBox[{"(", 
         RowBox[{"f0", "+", 
          RowBox[{"fDot", " ", "t"}]}], ")"}], " ", "t"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "tVals"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Template", ":", 
    RowBox[{
    "same", " ", "waveform", " ", "but", " ", "shifted", " ", "in", " ", 
     "time", " ", "by", " ", "20", " ", "ms", " ", "and", " ", "scaled", " ", 
     "by", " ", "2"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"dtShift", "=", "0.002"}], ";"}], "  ", 
  RowBox[{"(*", "seconds", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"shiftSamples", "=", 
   RowBox[{"Round", "[", 
    RowBox[{"dtShift", "*", "sampleRate"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"h2Raw", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"2", " ", "Pi", " ", 
        RowBox[{"(", 
         RowBox[{"f0", "+", 
          RowBox[{"fDot", " ", 
           RowBox[{"(", 
            RowBox[{"t", " ", "+", " ", "dtShift"}], ")"}]}]}], " ", ")"}], 
        RowBox[{"(", 
         RowBox[{"t", "+", " ", "dtShift"}], ")"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "tVals"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"h2Raw", "=", 
     RowBox[{"RotateLeft", "[", 
      RowBox[{"h1Raw", ",", "shiftSamples"}], "]"}]}], ";"}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"tVals2", " ", "=", " ", 
     RowBox[{"tVals", "[", 
      RowBox[{"[", 
       RowBox[{"1", ";;", 
        RowBox[{"-", "shiftSamples"}]}], "]"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"nTime", " ", "=", " ", 
     RowBox[{"nTime", " ", "-", " ", "shiftSamples"}]}], ";"}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Apply", " ", "a", " ", "Planck", " ", "taper", " ", "to", " ", "suppress",
     " ", "spectral", " ", "leakage", " ", "at", " ", "the", " ", "edges"}], 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"h1", "=", 
   RowBox[{"GWTaper", "[", "h1Raw", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"h2", "=", 
   RowBox[{"GWTaper", "[", "h2Raw", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"tVals2", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"n", "*", "deltaT"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", 
       RowBox[{
        RowBox[{"Length", "[", "h1", "]"}], " ", "-", "1"}]}], "}"}]}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Waveform length: \>\"", ",", "nTime", 
    ",", "\"\< samples  (\>\"", ",", "duration", ",", "\"\< s at \>\"", ",", 
    "sampleRate", ",", "\"\< Hz)\>\""}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Time shift applied to h2: \>\"", ",", "shiftSamples", 
    ",", "\"\< samples (\>\"", ",", 
    RowBox[{"dtShift", "*", "1000"}], ",", "\"\< ms)\>\""}], "]"}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.98756360886126*^9, 3.987563608863476*^9}, 
   3.987564500179084*^9, {3.987564608035665*^9, 3.987564661479068*^9}, {
   3.987564692036847*^9, 3.987564709725833*^9}, {3.987564811543517*^9, 
