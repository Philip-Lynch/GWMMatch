Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"matchDiscrete", ",", "peakIndex"}], "}"}], "=", 
   RowBox[{"GWMatch", "[", 
    RowBox[{
    "h1", ",", "h2", ",", "deltaT", ",", "psdFlat", ",", "deltaF", ",", 
     "fLow", ",", "fHigh"}], "]"}]}], ";"}], "\n", 
 RowBox[{
