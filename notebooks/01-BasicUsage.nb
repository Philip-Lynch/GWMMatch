8f186bf00a16"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"nFreq", "=", 
   RowBox[{
    RowBox[{"Floor", "[", 
     RowBox[{"nTime", "/", "2"}], "]"}], "+", "1"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"psdFlat", "=", 
   RowBox[{"FlatPSD", "[", 
    RowBox[{"nFreq", ",", "deltaF", ",", "fLow"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.98756395648442*^9, 3.9875639564866047`*^9}},
 CellLabel->
  "In[1169]:=",ExpressionUUID->"af174b53-c38a-40ea-8a57-69ab9106b27a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. Basic overlap (no time/phase maximization)   ", "Subsection",
 CellChangeTimes->{{3.987563971807787*^9, 
  3.987563976882175*^9}},ExpressionUUID->"81f6e790-1e73-4535-a472-\
72243f9296ef"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"FFT", " ", "the", " ", "tapered", " ", "waveforms"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"h1Tilde", "=", 
     RowBox[{"GWMMatch`Private`ForwardFFT", "[", 
      RowBox[{"h1", ",", "deltaT"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"h2Tilde", "=", 
     RowBox[{"GWMMatch`Private`ForwardFFT", "[", 
      RowBox[{"h2", ",", "deltaT"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"overlap", "=", 
     RowBox[{"GWOverlap", "[", 
      RowBox[{
      "h1Tilde", ",", "h2Tilde", ",", "psdFlat", ",", "deltaF", ",", "fLow", ",",
        "fHigh"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n-- GWOverlap (no maximization) --\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Overlap = \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"overlap", ",", "6"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<(Expected: << 1 because of the time shift)\>\"", "]"}],
     ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9875639936632*^9, 3.987563997790985*^9}},
 CellLabel->
  "In[1171]:=",ExpressionUUID->"aa84a317-93d7-4888-87dd-494cc17dd527"],

