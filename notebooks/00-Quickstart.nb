Notebook[{

Cell[CellGroupData[{
Cell["GWMMatch - 00: Quickstart Guide", "Title",
 CellChangeTimes->{{3.987587851661859*^9, 
  3.987587863562509*^9}},ExpressionUUID->"9584519c-6204-4693-bb63-\
51c236b75f7a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"<<", "GWMMatch`"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", "Parameters", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sampleRate", "=", "2048.0"}], ";", 
  RowBox[{"duration", "=", "2.0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"nTime", "=", 
   RowBox[{"Round", "[", 
    RowBox[{"sampleRate", "*", "duration"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"deltaT", "=", 
   RowBox[{"1.0", "/", "sampleRate"}]}], ";", 
  RowBox[{"deltaF", "=", 
   RowBox[{"1.0", "/", "duration"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"fLow", "=", "20.0"}], ";", 
  RowBox[{"fHigh", "=", "512.0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"nFreq", "=", 
    RowBox[{
     RowBox[{"Floor", "[", 
      RowBox[{"nTime", "/", "2"}], "]"}], "+", "1"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Build", " ", "two", " ", "waveforms"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tVals", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"n", " ", "deltaT"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", 
       RowBox[{"nTime", "-", "1"}]}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"h1", "=", 
   RowBox[{"GWTaper", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"2", " ", "Pi", " ", "60.0", " ", "t"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "tVals"}], "}"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"h2", "=", 
    RowBox[{"GWTaper", "[", 
     RowBox[{"RotateLeft", "[", 
      RowBox[{"h1", ",", "40"}], "]"}], "]"}]}], ";"}], "  ", 
  RowBox[{"(*", 
   RowBox[{"40", "-", 
    RowBox[{"sample", " ", "time", " ", "shift"}]}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Load", " ", "a", " ", "detector", " ", "PSD"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"psd", "=", 
    RowBox[{"DetectorPSD", "[", 
     RowBox[{"\"\<aLIGOZeroDetHighPower\>\"", ",", "nFreq", ",", "deltaF", ",",
       "fLow"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Compute", " ", "the", " ", "match"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"match", ",", "timeIndex"}], "}"}], "=", 
   RowBox[{"GWOptimizedMatch", "[", 
    RowBox[{
    "h1", ",", "h2", ",", "deltaT", ",", "psd", ",", "deltaF", ",", "fLow", ",",
      "fHigh"}], "]"}]}], ";"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Match = \>\"", ",", 
   RowBox[{"N", "[", 
    RowBox[{"match", ",", "8"}], "]"}]}], "]"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Mismatch = \>\"", ",", 
   RowBox[{"N", "[", 
    RowBox[{
     RowBox[{"1", "-", "match"}], ",", "8"}], "]"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.987587843864109*^9, 3.9875878438661127`*^9}, {
  3.987587963670494*^9, 3.9875879893861113`*^9}},
 CellLabel->
  "In[1303]:=",ExpressionUUID->"c2e841cf-9af7-4c30-b329-c7c0c8d1b37f"],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Match = \"\>", "\[InvisibleSpace]", "0.9977290300341265`"}],
  SequenceForm["Match = ", 0.9977290300341265],
  Editable->False]], "Print",
 CellChangeTimes->{
  3.987587870198369*^9, {3.9875879732221317`*^9, 3.987587990272952*^9}},
 CellLabel->
