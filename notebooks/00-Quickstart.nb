In[1303]:=",ExpressionUUID->"d72aa421-a1bd-45e5-a1cf-e2bf178c51cd"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Mismatch = \"\>", "\[InvisibleSpace]", 
   "0.002270969965873504`"}],
  SequenceForm["Mismatch = ", 0.002270969965873504],
  Editable->False]], "Print",
 CellChangeTimes->{
  3.987587870198369*^9, {3.9875879732221317`*^9, 3.987587990273999*^9}},
